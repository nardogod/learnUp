{
  "name": "learnup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "register-user": "tsx scripts/register-user.ts",
    "set-commands": "tsx scripts/set-bot-commands.ts",
    "admin": "tsx scripts/admin.ts",
    "test:ollama": "tsx scripts/test-ollama.ts",
    "docker:build": "docker build -t learnup-ollama ./ollama-render",
    "docker:run": "docker run -p 11434:11434 -e OLLAMA_MODEL=qwen2.5:1.5b learnup-ollama",
    "test:bot": "tsx scripts/test-bot-message.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "deploy:vercel": "vercel --prod",
    "deploy:commands": "npm run set-commands",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.4.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "inquirer": "^13.3.0",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
